<!DOCTYPE html>
<html>
<head>
  <title>The Collectable Habit</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0d1b2a;
      color: white;
    }

    header {
      background: black;
      padding: 20px;
      text-align: center;
      color: gold;
    }

    nav {
      text-align: center;
      padding: 10px;
      background: #1b263b;
    }

    nav a {
      color: gold;
      margin: 0 15px;
      text-decoration: none;
    }

    .hero {
      text-align: center;
      padding: 50px;
    }

    .products {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
    }

    .product {
      background: #1b263b;
      border: 1px solid gold;
      margin: 20px;
      padding: 20px;
      width: 250px;
      text-align: center;
    }

    .product img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    button {
      background: gold;
      border: none;
      padding: 10px;
      cursor: pointer;
      margin-top: 10px;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: black;
      margin-top: 40px;
    }
  </style>
</head>

<body>

<header>
  <h1>The Collectable Habit</h1>
  <p>Coins • Antiques • Collectables</p>
</header>

<nav>
  <a href="#">Home</a>
  <a href="#">Shop</a>
  <a href="#">Contact</a>
</nav>

<div class="hero">
  <h2>Rare Finds & Timeless Pieces</h2>
  <p>Browse our unique collection of coins and antiques</p>
</div>

<div class="products">

  <div class="product">
    <img src="https://via.placeholder.com/250" alt="Coin">
    <h3>Vintage Coin</h3>
    <p>£20</p>

    <!-- PAYPAL BUTTON -->
    <a href="https://www.paypal.com/paypalme/YOURNAME/20" target="_blank">
      <button>Buy Now</button>
    </a>
  </div>

  <div class="product">
    <img src="https://via.placeholder.com/250" alt="Antique">
    <h3>Antique Pocket Watch</h3>
    <p>£45</p>

    <a href="https://www.paypal.com/paypalme/j420ake/45" target="_blank">
      <button>Buy Now</button>
    </a>
  </div>

</div>

<footer>
  <p>© The Collectable Habit</p>
</footer>

</body>
</html>
